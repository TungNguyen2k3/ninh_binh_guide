generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  staff
  tourist
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  phone        String?  @unique
  passwordHash String
  name         String
  role         Role     @default(tourist)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]
  staffTickets  Ticket[]       @relation("StaffTickets")
  ticketUsers   TicketUser[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

enum PackageType {
  all_locations
  custom
}

model Location {
  id                String   @id @default(cuid())
  slug              String   @unique
  nameVi            String
  nameEn            String
  descriptionVi     String?  @db.Text
  descriptionEn     String?  @db.Text
  overviewVi        String?  @db.Text
  overviewEn        String?  @db.Text
  historyVi         String?  @db.Text
  historyEn         String?  @db.Text
  highlightsVi      String?  @db.Text
  highlightsEn      String?  @db.Text
  openTime          DateTime? @db.Time(6)
  closeTime         DateTime? @db.Time(6)
  estimatedDuration Int?
  address           String?
  bestTime          String?
  audioViUrl        String?
  audioEnUrl        String?
  imageUrl          String?
  latitude          Float
  longitude         Float
  displayOrder      Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  packages        PackageLocation[]
  locationImages  LocationImage[]
  spots           LocationSpot[]
  tourStops       TourStop[]
  admissionFees   LocationAdmissionFee[]

  @@map("locations")
}

model LocationAdmissionFee {
  id         String   @id @default(cuid())
  locationId String
  labelVi    String
  labelEn    String
  price      Int
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@map("location_admission_fees")
}

model Package {
  id            String      @id @default(cuid())
  name          String
  description   String?
  type          PackageType @default(custom)
  validityHours Int         @default(24)
  price         Int         @default(0)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  locations PackageLocation[]
  tickets   Ticket[]

  @@map("packages")
}

model PackageLocation {
  packageId  String
  locationId String
  order      Int    @default(0)

  package  Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([packageId, locationId])
  @@map("package_locations")
}

model LocationImage {
  id         String   @id @default(cuid())
  locationId String
  url        String
  caption    String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@map("location_images")
}

model LocationSpot {
  id            String   @id @default(cuid())
  locationId    String
  nameVi        String
  nameEn        String
  descriptionVi String?  @db.Text
  descriptionEn String?  @db.Text
  audioViUrl    String?
  audioEnUrl    String?
  latitude      Float?
  longitude     Float?
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  location Location           @relation(fields: [locationId], references: [id], onDelete: Cascade)
  images   LocationSpotImage[]

  @@map("location_spots")
}

model LocationSpotImage {
  id        String   @id @default(cuid())
  spotId    String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  spot LocationSpot @relation(fields: [spotId], references: [id], onDelete: Cascade)

  @@map("location_spot_images")
}

model Ticket {
  id               String    @id @default(cuid())
  code             String    @unique // NBG-XXXXXX
  packageId        String
  guestName        String
  guestPhone       String?
  note             String?
  expiresAt        DateTime
  isPaid           Boolean   @default(false)
  amountCollected  Int       @default(0)
  isCancelled      Boolean   @default(false)
  cancelledAt      DateTime?
  createdById      String // staff userId
  createdAt        DateTime  @default(now())

  package     Package      @relation(fields: [packageId], references: [id])
  createdBy   User         @relation("StaffTickets", fields: [createdById], references: [id])
  ticketUsers TicketUser[]

  @@map("tickets")
}

model TicketUser {
  id          String    @id @default(cuid())
  ticketId    String
  userId      String
  activatedAt DateTime  @default(now())
  expiresAt   DateTime?

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ticketId, userId])
  @@map("ticket_users")
}

model Tour {
  id           String     @id @default(cuid())
  nameVi       String
  nameEn       String
  duration     String
  badgeVi      String?
  badgeEn      String?
  noteVi       String?    @db.Text
  noteEn       String?    @db.Text
  isActive     Boolean    @default(true)
  displayOrder Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  stops TourStop[]

  @@map("tours")
}

model TourStop {
  id                String   @id @default(cuid())
  tourId            String
  locationId        String
  order             Int      @default(0)
  suggestedTime     String?
  suggestedDuration String?
  noteVi            String?  @db.Text
  noteEn            String?  @db.Text

  tour     Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id])

  @@map("tour_stops")
}
